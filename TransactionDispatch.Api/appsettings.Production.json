{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Dispatch": {
    "MaxParallelism": 64,
    "RetryCount": 5,
    "RetryDelayMilliseconds": 200,
    "ProgressSaveEvery": 500,
    "PollIntervalSeconds": 5,
    "MaxPollBatchSize": 100,
    "SupportedExtensions": [ ".xml" ]
  },
  "Idempotency": {
    "EnableFileIdempotency": true,
    "EnableFolderIdempotency": true,
    "FolderIdempotencyWindowMinutes": 60
  },
  "Kafka": {
    "BootstrapServers": "kafka-broker-1:9092,kafka-broker-2:9092,kafka-broker-3:9092",
    "Topic": "transactions-topic",
    "ClientId": "transaction-dispatch-service",
    "CompressionType": "snappy",
    "LingerMs": 20,
    "BatchSizeBytes": 131072,
    "QueueBufferingMaxKbytes": 1048576,
    "QueueBufferingMaxMessages": 1000000,
    "MessageTimeoutMs": 120000,
    "EnableIdempotence": true,
    "InFlightRequestsPerConnection": 5,
    "NumPartitions": 6,
    "ReplicationFactor": 3
  },
  "Persistence": {
    "Provider": "PostgreSQL",
    "ConnectionString": "Host=prod-db-host;Port=5432;Database=TransactionDispatchDB;Username=dispatch_user;Password=REPLACE_WITH_SECRET;Pooling=true;MinPoolSize=5;MaxPoolSize=50;CommandTimeout=60;"
  },
  "AllowedHosts": "yourdomain.com",
  "Security": {
    "ApiKey": "REPLACE_WITH_SECRET",
    "AllowedOrigins": [ "https://yourdomain.com" ]
  }
}
