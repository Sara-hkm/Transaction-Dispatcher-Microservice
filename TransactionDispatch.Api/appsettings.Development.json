{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Dispatch": {
    "MaxParallelism": 8,
    "RetryCount": 2,
    "RetryDelayMilliseconds": 500,
    "ProgressSaveEvery": 10,
    "PollIntervalSeconds": 3,
    "MaxPollBatchSize": 20,
    "SupportedExtensions": [ ".xml" ]
  },
  "Idempotency": {
    "EnableFileIdempotency": true,
    "EnableFolderIdempotency": true,
    "FolderIdempotencyWindowMinutes": 5
  },
  "Security": {
    "ApiKey": ""
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "transactions-topic",
    "ClientId": "transaction-dispatch-service",
    "CompressionType": "snappy",
    "LingerMs": 20,
    "BatchSizeBytes": 131072,
    "QueueBufferingMaxKbytes": 1048576,
    "QueueBufferingMaxMessages": 1000000,
    "MessageTimeoutMs": 120000,
    "EnableIdempotence": true,
    "InFlightRequestsPerConnection": 5,
    "NumPartitions": 6,
    "ReplicationFactor": 1
  },
  "Persistence": {
    "Provider": "PostgreSQL",
    "ConnectionString": "Host=localhost;Port=5432;Database=TransactionDispatchDB_Dev;Username=postgres;Password=P@ssw0rd;"
  }
}
