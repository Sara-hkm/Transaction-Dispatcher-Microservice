        {
            "name": "4 — Throughput ≥ 600 msg/s",
            "description": "Dispatches 6 000 XML files and asserts the service processes them at ≥ 600 files/second.\n\nPre-requisite — create the test data:\n```powershell\nNew-Item 'C:\\TestData\\throughput' -ItemType Directory -Force\n1..6000 | ForEach-Object {\n    \"<transaction><id>$_</id><payload>$('x' * 900)</payload></transaction>\" |\n    Out-File \"C:\\TestData\\throughput\\tx$_.xml\" -Encoding UTF8\n}\n```\n\nNote: After a successful run, the folder is blocked by idempotency for 60 minutes.\nChange `throughputFolderPath` to a new path and recreate the files to re-test sooner.",
            "item": [
                {
                    "name": "POST /dispatch-transactions — dispatch 6 000-file batch",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"folderPath\": \"{{throughputFolderPath}}\",\n    \"deleteAfterSend\": false\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/dispatch-transactions",
                            "host": ["{{baseUrl}}"],
                            "path": ["dispatch-transactions"]
                        }
                    },
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.collectionVariables.set('throughputPollAttempts', '0');",
                                    "// Record wall-clock time BEFORE the request so elapsed time includes network latency.",
                                    "pm.collectionVariables.set('throughputStartMs', String(Date.now()));"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 202 Accepted', () => pm.response.to.have.status(202));",
                                    "",
                                    "const body = pm.response.json();",
                                    "pm.test('Response contains throughputJobId', () => {",
                                    "    pm.expect(body.jobId).to.be.a('string').and.match(",
                                    "        /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i",
                                    "    );",
                                    "});",
                                    "pm.collectionVariables.set('throughputJobId', body.jobId);"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "GET /dispatch-status/{{throughputJobId}} — immediate poll (expect 102 In-Progress)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/dispatch-status/{{throughputJobId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["dispatch-status", "{{throughputJobId}}"]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// Polled immediately after submission — 6 000 files should still be in-flight,",
                                    "// so we expect 102 Processing. Accept 200 only on exceptionally fast machines.",
                                    "pm.test('Status is 102 Processing or 200 Completed', () => {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([102, 200]);",
                                    "});",
                                    "",
                                    "const body = pm.response.json();",
                                    "pm.test('State is Queued, Running, or Completed', () => {",
                                    "    pm.expect(body.state).to.be.oneOf(['Queued', 'Running', 'Completed']);",
                                    "});",
                                    "",
                                    "pm.test('Body has all expected fields', () => {",
                                    "    pm.expect(body).to.include.all.keys(",
                                    "        'progress','state','totalFiles','processed','successful','failed','error'",
                                    "    );",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "GET /dispatch-status/{{throughputJobId}} — poll to completion + assert ≥ 600 msg/s",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/dispatch-status/{{throughputJobId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["dispatch-status", "{{throughputJobId}}"]
                        }
                    },
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 1-second delay between polls; avoids hammering the API while still",
                                    "// adding minimal overhead to the elapsed-time measurement.",
                                    "const delay = ms => new Promise(resolve => setTimeout(resolve, ms));",
                                    "await delay(1000);"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const TERMINAL = ['Completed', 'Failed', 'Cancelled'];",
                                    "const body = pm.response.json();",
                                    "",
                                    "if (!TERMINAL.includes(body.state)) {",
                                    "    // Still running — loop back.",
                                    "    const attempts = parseInt(pm.collectionVariables.get('throughputPollAttempts') || '0');",
                                    "    // 300 attempts × 1 s = 5-minute max wait.",
                                    "    pm.expect(attempts, 'Throughput job did not complete within 300 s').to.be.below(300);",
                                    "    pm.collectionVariables.set('throughputPollAttempts', String(attempts + 1));",
                                    "    pm.execution.setNextRequest('GET /dispatch-status/{{throughputJobId}} — poll to completion + assert ≥ 600 msg/s');",
                                    "    return;",
                                    "}",
                                    "",
                                    "// ── Terminal state reached ──────────────────────────────────────",
                                    "pm.collectionVariables.set('throughputPollAttempts', '0');",
                                    "",
                                    "pm.test('Throughput job completed without error', () => {",
                                    "    pm.expect(body.state).to.eql('Completed');",
                                    "});",
                                    "",
                                    "pm.test('No files failed', () => {",
                                    "    pm.expect(body.failed).to.eql(0);",
                                    "});",
                                    "",
                                    "pm.test('successful equals totalFiles', () => {",
                                    "    pm.expect(body.successful).to.eql(body.totalFiles);",
                                    "});",
                                    "",
                                    "// ── Throughput calculation ──────────────────────────────────────",
                                    "// Elapsed time is measured from BEFORE the dispatch request was sent",
                                    "// (set in the pre-request script of the Dispatch step) to NOW,",
                                    "// so it includes real end-to-end wall-clock time including the poll delays.",
                                    "const startMs      = parseInt(pm.collectionVariables.get('throughputStartMs'));",
                                    "const elapsedSec   = (Date.now() - startMs) / 1000;",
                                    "const totalFiles   = body.totalFiles;",
                                    "const msgPerSecond = totalFiles / elapsedSec;",
                                    "",
                                    "console.log(",
                                    "    `Throughput: ${totalFiles} files / ${elapsedSec.toFixed(1)} s` +",
                                    "    ` = ${msgPerSecond.toFixed(0)} msg/s`",
                                    ");",
                                    "",
                                    "pm.test(",
                                    "    `Throughput ≥ 600 msg/s ` +",
                                    "    `(actual: ${msgPerSecond.toFixed(0)} msg/s — ` +",
                                    "    `${totalFiles} files in ${elapsedSec.toFixed(1)} s)`,",
                                    "    () => {",
                                    "        pm.expect(msgPerSecond).to.be.at.least(",
                                    "            600,",
                                    "            `Expected ≥ 600 msg/s but measured ${msgPerSecond.toFixed(0)} msg/s`",
                                    "        );",
                                    "    }",
                                    ");"
                                ]
                            }
                        }
                    ]
                }
            ]
        }

    ]
}
